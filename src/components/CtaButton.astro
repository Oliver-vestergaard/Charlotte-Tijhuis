---
import "../style/global.css";

const {
  text,
  href 
} = Astro.props;
---


  <a href={href}>
    <div class="btn_wrapper">
      <button class="btn">
        {text}
      </button>
    </div>
  </a>


<style>




  .btn_wrapper {
    display: inline-block;
    position: relative;
    line-height: 0;

    --clip: polygon(12% 0%, 88% 0%, 100% 20%, 100% 80%, 88% 100%, 12% 100%, 0% 80%, 0% 20%);
    clip-path: var(--clip);
    background: #f5d16b;
    padding: 1.5px;
  }

  .btn {
    display: block;
    font-family: Gowun Batang;
    padding: 10px 20px;
    cursor: pointer;
    border: none;
    font-size: 0.6872rem;
    background-color: #f5c3c8;

    clip-path: var(--clip);
    transition: background-color 0.4s ease;
  }

  .btn:hover {
    background-color: var(--background-color);
  }

  .btn_wrapper:hover {
    background: var(--purpleDecoration-color);
  }
@media (min-width: 801px) { 
    .btn {
   padding: 10px 30px;
    font-size: 1.3rem;
}
}
</style>
