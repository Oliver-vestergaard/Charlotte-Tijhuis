---
import {Image} from "astro:assets";
import sølvring from "../assets/imgForside/forside8pic.jpg"
import herrearmbånd from "../assets/imgForside/forsidepic9.webp"
import Card from "../components/Card.astro";
import Layout from "../layout/Layout.astro";
import CtaButton from "../components/CtaButton.astro";
---

<Layout title="Forside">
  <div class="video_knap">
    <video class="video" autoplay muted loop playsinline src="/forsidevideo.mp4"> </video>
    <section class="skriftogknap">
      <h2 class="overskrift1">Nøje udvalgte smykker</h2>
      
      <CtaButton text="Se signatursmykker" href={`/productList`} />
    
    </section>
    </div>
    <div>
      <div class="tekst">
        <h2 class="h2tekst">Tidsløs elegance skabt med omtanke</h2>
        <p class="ptekst">I den lyserøde bygning på Helsingørsgade 3 i Hillerød finder du min guldsmedebutik — et sted fyldt med varme og passion, hvor mit håndværk bliver skabt fra bunden med sit autentiske udtryk og sans for organiske former. Her forenes tidløst design med ægte håndværk, og hvert smykke bliver skabt med omtanke, personlighed og fokus på kvalitet. Jeg tror på smykker, der ikke blot er smukke at bære, men som også fortæller en historie og kan følge dig gennem livet.</p>
      </div>
    </div>

    <section class="grid1-4">
      <img class="pic1" src="src/assets/imgForside/forsidepic1.webp" alt="Billede af en guldring bestående af 8 billianter" />
      <h3 class="skrift">Se mine signatur smykker</h3>

      <div class="grid1-2">
        <img src="src/assets/imgForside/forside2pic.webp" alt="Billede af ring med stor lyserød brilliant" />
        <img src="src/assets/imgForside/forside3pic.webp" alt="Billede af ring med stor grøn brilliant" />
        <img src="src/assets/imgForside/forsidepic4.webp" alt="Billede af armbånd med grønne sten" />
        <img src="src/assets/imgForside/forside5pic.webp" alt="Billede af halskæde med lyserød brilliant og 14kt guld rundt om" />
      </div>
    </section>

    <div class="wrappercard1">
    <Card  text="Find dine nye favoritter blandt mine unikke bestseller-smykker, designet med omtanke, personlighed og smukke farver. Du har også mulighed for at designe dit eget smykke i samarbejde med mig, så det bliver præcis, som du ønsker."
    image="src/assets/imgForside/forsidepic6.webp"
    title="Billede af fire ringe" ></Card>
</div>

    <h2 class="h2tekst2">Tidsløse herresmykker med kant</h2>

    <div class="grid1-1">
      <img class="topbillede" src="src/assets/imgForside/forsidepic7.webp" alt="Billede af to læderarmbånd med et kompas, den ene i sort og det andet i brunt" />
      <Image  class="topbillede" src={sølvring} format="webP" alt="Billede af en herre sølv ring med et kompas"/>
      <div class="tekst2">
        <p>Rustikke, rå og tidløse herresmykker. Laves på bestilling efter dine ønsker i sølv, guld eller læder. Herresmykkerne er til dig, der ønsker noget anderledes, råt og maskulint. </p>
      </div>

<Image  class="bundbillede" src={herrearmbånd} width={1000} format="webP" alt="Billede af et herrearmånd med forskellige grønne perler"/>
      
    </div>

    <h3 class="skrift">Kundeudtalelser:</h3>

    <section class="grid2">
      <div class="anmeldelse">
        <p>"Den bedste guldsmed, altid imødekommende, og kreativ ❤️."</p>
        <p class="navn">-Joan Lund</p>
      </div>

      <div class="anmeldelse">
        <p>"Charlotte er en spændende og utraditionel guldsmed. Vil varmt anbefale."</p>
        <p class="navn">-Michael Rögen</p>
      </div>
    </section>

    <h4 class="citat">“Hvis du ved hvordan du vil have det så kommer det til dig - der er altid en vej”</h4>

    <style>

      /* Video, overskrift og Knap */
      .video_knap {
        position: relative;  /* Gør det muligt at placere elementer ovenpå videoen */
        width: 100%;
        z-index: 1;  /* Bestemmer hvilket lag vidoen ligger på */
      }

      .video {
        width: 100%;
        height: auto;
        display: block;
      }

      .skriftogknap {
        position: absolute;  /* Placerer skrift og knap ovenpå videoen  */
        top: 60%;
        display: flex;
        flex-direction: column;  /* Skrift og knap er placeret under hinanden */
        justify-content: center;  /* centrerer indholdet */
        padding-left: 8%;
        gap: 10px;
        z-index: 2;  /* Bestemmer laget - ligger sig ovenpå videoen */
        
      }


      .overskrift1 {
        color: var(--background-color);
        margin-bottom: 0 auto;
      }

    
      /* Overskrift og tekstafsnit */

      .tekst {
        padding: 50px;
  
      }

      .h2tekst {
        margin-top: 2rem;
        margin-bottom: 1rem;
        text-align: center;
      }

      .ptekst {
        margin: 0 auto;
      }

      /* Fem billeder og overskrift */

      .grid1-4 {
        margin: 0 auto;
        padding: 0rem 3rem;
      }

      .pic1 {
        width: 100%;
        margin-bottom: 2rem;
      }

      .skrift {
        text-align: center;
        margin-bottom: 1rem;
      }

      .grid1-2 {
        display: grid;
        grid-template-columns: 1fr 1fr; /* to lige store kolonner  */
        gap: 1rem;
        margin-bottom: 4rem;
      }

      /* Komponentcard afsnit */

      .wrappercard1{
       margin-top: 6rem;
       margin-bottom: 5rem;
      }

      /* Overskrift, tre billeder og tekstafsnit  */

      .h2tekst2 {
        margin-bottom: 2rem;
        margin-top: 4rem;
        text-align: center;
      }
      .grid1-1 {
        display: grid;
        grid-template-columns: 1fr 1fr;  /* to lige store kolonner  */
      }

      .grid1-1 img {
        object-fit: cover; /* Sørger for at billederne bliver beskåret pænt og fylder hele boksen */
      }

      .topbillede {
        height: 160px;
      }

      .tekst2 {
        padding: 1rem;
      }

      .bundbillede {
        height: 160px;
        margin-bottom: 4rem;
      }

      /* Anmeldelse afsnit  */

      .grid2 {
        display: flex;
        flex-direction: row; /* Lægger boksene ved siden af hinanden */
        gap: 20px;
        padding: 5px 10px;
        justify-content: center;
       
      }

      .anmeldelse {
        background-color: var(--section-color);
        padding: 30px;
        width: 300px;  /* Fast bredde på anmeldelsesboksen */
        margin-bottom: 1rem;
      }

      .navn{
        margin-top: 1rem;
        
      }


      /* Citat */


      .citat {
        text-align: center;
        padding: 2rem;
      }


      /* Desktop version */

      @media (min-width: 800px){
        
       /* Knap over forsidevideo */
         .skriftogknap {
          top: 70%;
        }
        
        /* Overskrift og tekstafsnit */
        
        .h2tekst {
          margin-top: 8rem;
        }

        /* Fem billeder og overskrift */

        .grid1-4 {
          display: grid;
          grid-template-columns: 2fr 1fr 1fr;  /* Laver tre kolonner: Den første kolonne er størst og de to andre er mindre */
          gap: 20px;
          max-width: 1400px;
          margin: auto;
          padding: 40px;
        }

        .pic1 {
          grid-row: 1 / 4; /* Billedet fylder fra kolonne 1 til 4 */
        }
        .skrift {
          margin-top: 4rem;
          grid-column: 2 / 4; /* Teksten fylder fra kolonne 2 til 4 */
        }

        .grid1-2 {
          grid-column: 2 / 4; /* billederne fylder fra kolonne 2 til 4 */
        }

        .topbillede {
          height: 370px;
        }

        .tekst2 {
          margin-top: 2rem ;
          padding: 3rem;
        }

        .bundbillede {
          height: 370px;
          margin-bottom: 5rem;
        }

        /* Komponentcard afsnit */

        .wrappercard1{
        margin-top: 8rem;
        margin-bottom: 9rem;
        }

        /* Anmeldelse afsnit */

        .grid2 {
          display: flex;
          justify-content: center;
          gap: 40px;
        }

        .anmeldelse {
          width: 500px; /* Giver boksen en fast bredde */
          padding: 70px;
          margin-bottom: 4rem;
        }
      }

 
    

    </style>
  </div>
</Layout>
